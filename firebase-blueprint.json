{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User settings and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "username": { "type": "string", "description": "The display name of the user" },
        "email": { "type": "string", "format": "email", "description": "The email of the user" },
        "photoURL": { "type": "string", "description": "The photo URL of the user" },
        "reciter": { "type": "string", "description": "Preferred reciter ID" },
        "model": { "type": "string", "description": "Preferred Gemini model" },
        "creativityLevel": { "type": "number", "description": "AI creativity level" },
        "apiKey": { "type": "string", "description": "Optional custom API key" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "When the settings were last updated" }
      },
      "required": ["uid", "username"]
    },
    "Session": {
      "title": "Chat Session",
      "description": "A single chat session with multiple messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "number" },
        "preview": { "type": "string" },
        "messages": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "date", "preview", "messages"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User-specific settings and profile"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "User's chat history sessions"
    }
  }
}
